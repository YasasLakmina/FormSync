{
    "name": "backend-dto-generator",
    "version": "1.0.0",
    "description": "Backend DTO Generator for FormSync",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "postbuild": "npm run copy-templates",
        "copy-templates": "cpx \"src/templates/**/*.{hbs,xml}\" dist/apps/backend-dto-generator/src/templates",
        "start": "node dist/index.js",
        "dev": "ts-node src/index.ts",
        "lint": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "dependencies": {
        "@formsync/plugins": "*",
        "archiver": "^7.0.1",
        "axios": "^1.13.2",
        "axios-retry": "^4.5.0",
        "body-parser": "^2.2.1",
        "cors": "^2.8.5",
        "cpx": "^1.5.0",
        "express": "^5.2.1",
        "fs-extra": "^11.3.3",
        "handlebars": "^4.7.8",
        "typescript": "^5.2.2",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@types/archiver": "^7.0.0",
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/fs-extra": "^11.0.4",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.10.5",
        "@types/uuid": "^10.0.0",
        "jest": "^30.2.0",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2"
    }
}
