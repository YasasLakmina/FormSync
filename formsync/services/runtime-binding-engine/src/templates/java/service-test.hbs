/**
 * Unit tests for {{name}}Service.
 * Uses Mockito to mock the repository layer.
 */
@ExtendWith(MockitoExtension.class)
class {{name}}ServiceTest {

    @Mock
    private {{name}}Repository repository;

    @InjectMocks
    private {{name}}Service service;

    /**
     * Builds a valid {{name}} entity for testing.
     */
    private {{name}} buildEntity() {
        return {{name}}.builder()
                .id(1L)
{{#each fields}}
                .{{name}}({{{testValue type referenceType constraints}}})
{{/each}}
                .build();
    }

    /**
     * Builds a valid {{name}}Request for testing.
     */
    private {{name}}Request buildRequest() {
        return {{name}}Request.builder()
{{#each fields}}
                .{{name}}({{{testValue type referenceType constraints}}})
{{/each}}
                .build();
    }

    // ═══════════════════════════════════════════
    //  findAll
    // ═══════════════════════════════════════════

    @Nested
    @DisplayName("findAll")
    class FindAll {

        @Test
        @DisplayName("should return list of responses")
        void shouldReturnList() {
            when(repository.findAll()).thenReturn(List.of(buildEntity()));

            List<{{name}}Response> result = service.findAll();

            assertNotNull(result);
            assertEquals(1, result.size());
            verify(repository).findAll();
        }

        @Test
        @DisplayName("should return empty list when no entities exist")
        void shouldReturnEmptyList() {
            when(repository.findAll()).thenReturn(Collections.emptyList());

            List<{{name}}Response> result = service.findAll();

            assertNotNull(result);
            assertTrue(result.isEmpty());
        }
    }

    // ═══════════════════════════════════════════
    //  findById
    // ═══════════════════════════════════════════

    @Nested
    @DisplayName("findById")
    class FindById {

        @Test
        @DisplayName("should return response when entity exists")
        void shouldReturnEntity() {
            {{name}} entity = buildEntity();
            when(repository.findById(1L)).thenReturn(Optional.of(entity));

            {{name}}Response result = service.findById(1L);

            assertNotNull(result);
            assertEquals(entity.getId(), result.getId());
        }

        @Test
        @DisplayName("should throw ResourceNotFoundException when entity not found")
        void shouldThrowWhenNotFound() {
            when(repository.findById(999L)).thenReturn(Optional.empty());

            assertThrows(ResourceNotFoundException.class, () -> service.findById(999L));
        }
    }

    // ═══════════════════════════════════════════
    //  create
    // ═══════════════════════════════════════════

    @Nested
    @DisplayName("create")
    class Create {

        @Test
        @DisplayName("should save entity and return response")
        void shouldCreateAndReturn() {
            {{name}} entity = buildEntity();
            when(repository.save(any({{name}}.class))).thenReturn(entity);

            {{name}}Response result = service.create(buildRequest());

            assertNotNull(result);
            assertEquals(entity.getId(), result.getId());
            verify(repository).save(any({{name}}.class));
        }
    }

    // ═══════════════════════════════════════════
    //  update
    // ═══════════════════════════════════════════

    @Nested
    @DisplayName("update")
    class Update {

        @Test
        @DisplayName("should update entity and return response")
        void shouldUpdateAndReturn() {
            {{name}} entity = buildEntity();
            when(repository.existsById(1L)).thenReturn(true);
            when(repository.save(any({{name}}.class))).thenReturn(entity);

            {{name}}Response result = service.update(1L, buildRequest());

            assertNotNull(result);
            verify(repository).existsById(1L);
            verify(repository).save(any({{name}}.class));
        }

        @Test
        @DisplayName("should throw ResourceNotFoundException when entity not found")
        void shouldThrowWhenNotFound() {
            when(repository.existsById(999L)).thenReturn(false);

            assertThrows(ResourceNotFoundException.class, () -> service.update(999L, buildRequest()));
            verify(repository, never()).save(any());
        }
    }

    // ═══════════════════════════════════════════
    //  deleteById
    // ═══════════════════════════════════════════

    @Nested
    @DisplayName("deleteById")
    class DeleteById {

        @Test
        @DisplayName("should delete entity when it exists")
        void shouldDelete() {
            when(repository.existsById(1L)).thenReturn(true);
            doNothing().when(repository).deleteById(1L);

            assertDoesNotThrow(() -> service.deleteById(1L));
            verify(repository).deleteById(1L);
        }

        @Test
        @DisplayName("should throw ResourceNotFoundException when entity not found")
        void shouldThrowWhenNotFound() {
            when(repository.existsById(999L)).thenReturn(false);

            assertThrows(ResourceNotFoundException.class, () -> service.deleteById(999L));
            verify(repository, never()).deleteById(any());
        }
    }
}
