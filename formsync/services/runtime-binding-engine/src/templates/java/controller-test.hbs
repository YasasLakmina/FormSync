    // ═══════════════════════════════════════════
    //  PUT  /api/{{toKebabCase name}}s/{id}
    // ═══════════════════════════════════════════

    @Nested
    @DisplayName("PUT " + BASE_URL + "/{id}")
    class Update {

        @Test
        @DisplayName("should update existing entity")
        void shouldUpdate() throws Exception {
            Long id = createEntityAndGetId();

            mockMvc.perform(put(BASE_URL + "/{id}", id)
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(objectMapper.writeValueAsString(buildValidRequest())))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.id").value(id));
        }

        @Test
        @DisplayName("should return 404 when updating non-existent entity")
        void shouldReturn404() throws Exception {
            mockMvc.perform(put(BASE_URL + "/{id}", 999L)
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(objectMapper.writeValueAsString(buildValidRequest())))
                    .andExpect(status().isNotFound());
        }
    }

    // ═══════════════════════════════════════════
    //  DELETE  /api/{{toKebabCase name}}s/{id}
    // ═══════════════════════════════════════════

    @Nested
    @DisplayName("DELETE " + BASE_URL + "/{id}")
    class Delete {

        @Test
        @DisplayName("should delete existing entity")
        void shouldDelete() throws Exception {
            Long id = createEntityAndGetId();

            mockMvc.perform(delete(BASE_URL + "/{id}", id))
                    .andExpect(status().isNoContent());

            // Confirm it's gone
            mockMvc.perform(get(BASE_URL + "/{id}", id))
                    .andExpect(status().isNotFound());
        }

        @Test
        @DisplayName("should return 404 when deleting non-existent entity")
        void shouldReturn404() throws Exception {
            mockMvc.perform(delete(BASE_URL + "/{id}", 999L))
                    .andExpect(status().isNotFound());
        }
