var builder = WebApplication.CreateBuilder(args);

builder.Services.AddControllers();
builder.Services.AddEndpointsApiExplorer();
{{#if includeSwagger}}
builder.Services.AddSwaggerGen(c =>
    c.SwaggerDoc("v1", new() { Title = "{{appName}} API", Version = "{{apiVersion}}", Description = "{{apiDescription}}" }));
{{/if}}

{{#each entities}}
builder.Services.AddScoped<{{namespace}}.Repositories.I{{name}}Repository, {{namespace}}.Repositories.{{name}}Repository>();
builder.Services.AddScoped<{{namespace}}.Services.I{{name}}Service, {{namespace}}.Services.{{name}}Service>();
{{/each}}

var app = builder.Build();

const string FormsyncAscii = {{{formsyncBannerJson}}};

app.Lifetime.ApplicationStarted.Register(() =>
{
    const string Purple = "\x1b[95m";
    const string Reset = "\x1b[0m";
    Console.Write(Purple);
    Console.Write(FormsyncAscii.TrimEnd());
    Console.WriteLine(Reset);
    Console.WriteLine($"{Purple}:: FormSync ::{Reset}");
    Console.WriteLine($"API listening at http://localhost:{{serverPort}}");
});

{{#if includeSwagger}}
app.MapGet("/openapi.yaml", () =>
{
    var yamlPath = Path.Combine(app.Environment.ContentRootPath, "openapi.yaml");
    return Results.File(yamlPath, contentType: "application/yaml");
});

app.UseSwagger();
app.UseSwaggerUI();
{{/if}}

app.UseHttpsRedirection();
app.UseAuthorization();
app.MapControllers();
app.Run();
