    public IEnumerable<{{name}}> GetAll() => _store.ToList();

    public {{name}}? GetById(int id) => _store.FirstOrDefault(e => e.Id == id);

    public void Add({{name}} entity)
    {
        entity.Id = _nextId++;
        _store.Add(entity);
