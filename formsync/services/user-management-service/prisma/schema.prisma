// This is the Prisma schema for the user-api service
// It points to the SAME PostgreSQL database as schema-api
// but is used only for prisma generate (user-api owns User + FormTemplate)

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String         @id @default(uuid())
  email       String         @unique
  name        String?
  password    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  schemas     Schema[]
  templates   FormTemplate[]
  srsProjects SrsProject[]
}

model Schema {
  id           String    @id @default(uuid())
  name         String
  description  String?
  content      Json
  sourceFormat String    @default("json")
  tags         String[]
  status       String    @default("draft")
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  version      Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model FormTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  content     Json
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model SrsProject {
  id          String      @id @default(uuid())
  name        String
  description String?
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userStories UserStory[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
}

model UserStory {
  id                 String     @id @default(uuid())
  title              String
  role               String
  action             String
  benefit            String
  acceptanceCriteria String[]
  suggestedFields    Json
  featureArea        String     @default("General")
  confidence         Float      @default(0)
  status             String     @default("draft")
  generatedSchemaId  String?
  rawText            String     @default("")
  projectId          String
  project            SrsProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([projectId])
}
