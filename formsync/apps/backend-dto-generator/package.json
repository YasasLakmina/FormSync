{
    "name": "backend-dto-generator",
    "version": "1.0.0",
    "description": "Backend DTO Generator for FormSync",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "postbuild": "npm run copy-templates",
        "copy-templates": "cpx \"src/templates/**/*.{hbs,xml}\" dist/apps/backend-dto-generator/src/templates",
        "start": "node dist/index.js",
        "dev": "ts-node src/index.ts",
        "lint": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "dependencies": {
        "@formsync/plugins": "*",
        "axios": "^1.13.2",
        "axios-retry": "^4.5.0",
        "handlebars": "^4.7.8",
        "typescript": "^5.2.2"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^20.10.5",
        "cpx": "^1.5.0",
        "jest": "^30.2.0",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2"
    }
}