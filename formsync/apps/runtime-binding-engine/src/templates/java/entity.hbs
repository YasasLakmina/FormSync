package {{basePackage}}.model;

import jakarta.persistence.*;
import jakarta.validation.constraints.*;
import lombok.AllArgsConstructor;
import lombok.Builder;
import lombok.Data;
import lombok.NoArgsConstructor;
import java.util.*;
import java.time.*;
import java.math.*;

/**
{{#if description}}
 * {{description}}
{{else}}
 * Entity class for {{name}}.
{{/if}}
 */
@Data
@Builder
@NoArgsConstructor
@AllArgsConstructor
@Entity
@Table(name = "{{toSnakeCase name}}")
public class {{name}} {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

{{#each fields}}
{{#if description}}
    /**
     * {{description}}
     */
{{/if}}
{{#if constraints.required}}
{{#eq type 'String'}}
{{#if constraints.notBlank}}
    @NotBlank(message = "{{name}} is required")
{{else}}
    @NotNull(message = "{{name}} is required")
{{/if}}
{{else}}
    @NotNull(message = "{{name}} is required")
{{/eq}}
{{/if}}
{{#if constraints.email}}
    @Email(message = "{{name}} must be a valid email address")
{{/if}}
{{#if constraints.min}}
{{#eq type 'Double'}}
    @DecimalMin(value = "{{constraints.min}}", message = "{{name}} must be at least {{constraints.min}}")
{{else}}
    @Min(value = {{constraints.min}}, message = "{{name}} must be at least {{constraints.min}}")
{{/eq}}
{{/if}}
{{#if constraints.max}}
{{#eq type 'Double'}}
    @DecimalMax(value = "{{constraints.max}}", message = "{{name}} must be at most {{constraints.max}}")
{{else}}
    @Max(value = {{constraints.max}}, message = "{{name}} must be at most {{constraints.max}}")
{{/eq}}
{{/if}}
{{#if constraints.minLength}}
    @Size(min = {{constraints.minLength}}{{#if constraints.maxLength}}, max = {{constraints.maxLength}}{{/if}}, message = "{{name}} must be between {{constraints.minLength}} and {{#if constraints.maxLength}}{{constraints.maxLength}}{{else}}unlimited{{/if}} characters")
{{else}}
{{#if constraints.maxLength}}
    @Size(max = {{constraints.maxLength}}, message = "{{name}} must be at most {{constraints.maxLength}} characters")
{{/if}}
{{/if}}
{{#if constraints.pattern}}
    @Pattern(regexp = "{{constraints.pattern}}", message = "{{name}} must match pattern {{constraints.pattern}}")
{{/if}}
    @Column(nullable = {{#if constraints.required}}false{{else}}true{{/if}})
{{#eq type 'List'}}
    @ElementCollection
{{/eq}}
    private {{toJavaType type referenceType}} {{name}};

{{/each}}
}
